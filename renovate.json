{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>m0sh1/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "pinDigests": false,
  "ignorePaths": [
    "charts/*/*.tgz"
  ],
  "enabledManagers": [
    "gomod",
    "dockerfile",
    "github-actions",
    "helmv3",
    "helm-values"
  ],
  "helmv3": {
    "managerFilePatterns": [
      "/charts/latest/csi-driver-nfs/Chart\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/charts/latest/csi-driver-nfs/values\\.yaml$/"
    ]
  },
  "packageRules": [
    {
      "description": "Patch-bump the active Helm chart version when Renovate changes chart dependencies or values",
      "matchManagers": ["helmv3", "helm-values"],
      "matchFileNames": [
        "charts/latest/csi-driver-nfs/Chart.yaml",
        "charts/latest/csi-driver-nfs/values.yaml"
      ],
      "addLabels": ["helm"],
      "bumpVersions": [
        {
          "name": "Patch-bump active CSI NFS Helm Chart.yaml",
          "filePatterns": ["charts/latest/csi-driver-nfs/Chart.yaml"],
          "matchStrings": ["version:\\s*\"?v?(?<version>\\d+\\.\\d+\\.\\d+)\"?"],
          "bumpType": "patch"
        }
      ]
    },
    {
      "matchManagers": ["gomod"],
      "addLabels": ["go"]
    },
    {
      "matchManagers": ["dockerfile"],
      "addLabels": ["docker"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "description": "Group all GitHub Actions into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Auto-merge patch and minor Go module updates",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "automerge": true
    }
  ]
}
